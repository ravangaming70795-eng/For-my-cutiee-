<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>For My Madam ❤️</title>
    <style>
        :root {
            --primary-color: #ff4d6d;
            --secondary-color: #ff85a1;
            --bg-color: #fff0f3;
            --text-color: #2b2d42;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-color);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
        }

        .container {
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            width: 90%;
            max-width: 500px;
            text-align: center;
            position: relative;
            transition: all 0.5s ease;
        }

        .step {
            display: none;
            animation: fadeIn 0.5s ease forward;
        }

        .step.active {
            display: block;
        }

        h1 {
            color: var(--primary-color);
            margin-bottom: 20px;
            font-size: 24px;
        }

        p {
            font-size: 18px;
            line-height: 1.6;
            margin-bottom: 25px;
        }

        .btn-container {
            display: flex;
            justify-content: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        button {
            padding: 12px 28px;
            font-size: 16px;
            font-weight: bold;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            transition: transform 0.2s, background-color 0.2s;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .btn-primary {
            background-color: var(--primary-color);
            color: white;
        }

        .btn-primary:hover {
            background-color: #ff1a43;
            transform: scale(1.05);
        }

        .btn-secondary {
            background-color: #e2e8f0;
            color: #4a5568;
        }

        .btn-secondary:hover {
            background-color: #cbd5e1;
        }

        /* Dummy Game Styling */
        .dummy-container {
            position: relative;
            width: 200px;
            height: 250px;
            margin: 0 auto 20px;
            cursor: pointer;
        }

        .dummy {
            width: 100%;
            height: 100%;
            background: #fbc4ab;
            border-radius: 20px;
            position: relative;
            border: 4px solid #f08080;
            overflow: hidden;
            transition: transform 0.1s;
        }

        /* Simple CSS representation of the cartoon dummy */
        .dummy-head {
            width: 90px;
            height: 90px;
            background: #ffdbac;
            border-radius: 50%;
            position: absolute;
            top: 20px;
            left: 55px;
            border: 3px solid #e0a96d;
        }
        .dummy-hair {
            width: 100px;
            height: 40px;
            background: #2b2d42;
            border-radius: 50px 50px 0 0;
            position: absolute;
            top: 12px;
            left: 50px;
        }
        .dummy-eyes {
            width: 12px;
            height: 12px;
            background: #2b2d42;
            border-radius: 50%;
            position: absolute;
            top: 45px;
            left: 75px;
            box-shadow: 25px 0 #2b2d42;
        }
        .dummy-shirt {
            width: 130px;
            height: 110px;
            background: #ffffff;
            border-radius: 20px 20px 0 0;
            position: absolute;
            bottom: 10px;
            left: 35px;
            border: 3px solid #cbd5e1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: #94a3b8;
            font-size: 14px;
        }

        .dummy.hit {
            animation: shake 0.15s infinite;
            background: #ff85a1;
        }

        .hit-effect {
            position: absolute;
            color: red;
            font-weight: bold;
            font-size: 24px;
            pointer-events: none;
            animation: floatUp 0.4s ease-out forwards;
            z-index: 10;
        }

        .progress-bar {
            width: 100%;
            background-color: #e2e8f0;
            border-radius: 10px;
            margin-bottom: 20px;
            height: 15px;
            overflow: hidden;
        }

        .progress {
            width: 0%;
            height: 100%;
            background-color: var(--primary-color);
            transition: width 0.1s ease;
        }

        .bouquet-img {
            font-size: 80px;
            margin-bottom: 20px;
            animation: bounce 2s infinite;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes shake {
            0% { transform: translate(2px, 1px) rotate(0deg); }
            10% { transform: translate(-1px, -2px) rotate(-1deg); }
            20% { transform: translate(-3px, 0px) rotate(1deg); }
            30% { transform: translate(0px, 2px) rotate(0deg); }
            40% { transform: translate(1px, -1px) rotate(1deg); }
            50% { transform: translate(-1px, 2px) rotate(-1deg); }
            60% { transform: translate(-3px, 1px) rotate(0deg); }
            70% { transform: translate(2px, 1px) rotate(-1deg); }
            80% { transform: translate(-1px, -1px) rotate(1deg); }
            90% { transform: translate(2px, 2px) rotate(0deg); }
            100% { transform: translate(1px, -2px) rotate(-1deg); }
        }

        @keyframes floatUp {
            0% { opacity: 1; transform: translateY(0) scale(1); }
            100% { opacity: 0; transform: translateY(-40px) scale(1.2); }
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-20px); }
            60% { transform: translateY(-10px); }
        }
    </style>
</head>
<body>

<div class="container">
    
    <!-- STEP 1: The Apology -->
    <div id="step1" class="step active">
        <h1>I am SO Sorry! 🥺</h1>
        <p>I know I made a mistake, and I feel terrible about it. You are my absolute priority. Do you want to beat me up for this?</p>
        <div class="btn-container">
            <button class="btn-primary" onclick="goToStep(2)">Yes, absolutely!</button>
            <button class="btn-secondary" id="notBtn" onclick="handleNotChoice()">No, it's fine...</button>
        </div>
    </div>

    <!-- STEP 1 Alternate: Force "Yes" -->
    <div id="step1-alt" class="step">
        <h1>Please? 🥺</h1>
        <p>No, please beat me! I won't feel better until you release your anger on me. Come on, punish me for my mistake!</p>
        <div class="btn-container">
            <button class="btn-primary" onclick="goToStep(2)">Okay, fine! 🥊</button>
        </div>
    </div>

    <!-- STEP 2: Beating the Dummy -->
    <div id="step2" class="step">
        <h1>Punish Me! 🥊</h1>
        <p>I am always yours. You have full right to beat me for my mistakes. Tap the dummy below to punch me until the bar is full!</p>
        
        <div class="progress-bar">
            <div id="punchProgress" class="progress"></div>
        </div>

        <div class="dummy-container" onclick="punchDummy(event)">
            <div id="dummyTarget" class="dummy">
                <div class="dummy-hair"></div>
                <div class="dummy-head"></div>
                <div class="dummy-eyes"></div>
                <div class="dummy-shirt">DUMMY ME</div>
            </div>
        </div>
        <p style="font-size: 14px; color: #718096;" id="hitCountTxt">Hits: 0 / 10</p>
    </div>

    <!-- STEP 3: Feeling Good? -->
    <div id="step3" class="step">
        <h1>Are you feeling better now? 😊</h1>
        <p>Hopefully, beating me up brought a little smile back to your face!</p>
        <div class="btn-container">
            <button class="btn-primary" onclick="goToStep(4)">Yes, much better!</button>
        </div>
    </div>

    <!-- STEP 4: The Proposal -->
    <div id="step4" class="step">
        <div class="bouquet-img">💐</div>
        <h1>My Final Proposal... 💖</h1>
        <p>Now that you've forgiven me, I want to say what is truly in my heart...</p>
        <h2 style="color: var(--primary-color); margin-bottom: 25px; font-size: 26px;">I Love You Forever, My Madam! 🥰</h2>
        <p style="font-style: italic; font-size: 16px;">Will you stay by my side and let me make it up to you every single day?</p>
        <div class="btn-container">
            <button class="btn-primary" onclick="celebrate()">YES! 💖</button>
        </div>
    </div>

</div>

<script>
    let hitCount = 0;
    const totalRequiredHits = 10;

    function goToStep(stepNum) {
        // Hide all steps
        document.querySelectorAll('.step').forEach(step => {
            step.classList.remove('active');
        });
        
        // Show target step
        if(stepNum === 2) {
            document.getElementById('step2').classList.add('active');
        } else if(stepNum === 3) {
            document.getElementById('step3').classList.add('active');
        } else if(stepNum === 4) {
            document.getElementById('step4').classList.add('active');
        }
    }

    function handleNotChoice() {
        document.querySelectorAll('.step').forEach(step => {
            step.classList.remove('active');
        });
        document.getElementById('step1-alt').classList.add('active');
    }

    function punchDummy(event) {
        const dummy = document.getElementById('dummyTarget');
        hitCount++;
        
        // Update Progress Bar
        const percentage = (hitCount / totalRequiredHits) * 100;
        document.getElementById('punchProgress').style.width = percentage + '%';
        document.getElementById('hitCountTxt').innerText = `Hits: ${hitCount} / ${totalRequiredHits}`;

        // Add Hit Text Effect
        const container = document.querySelector('.dummy-container');
        const hitTxt = document.createElement('div');
        hitTxt.classList.add('hit-effect');
        hitTxt.innerText = ['POW!', 'BAM!', 'OUCH!', 'SORRY!'][Math.floor(Math.random() * 4)];
        hitTxt.style.left = (event.offsetX - 20) + 'px';
        hitTxt.style.top = (event.offsetY - 20) + 'px';
        container.appendChild(hitTxt);

        // Shake animation
        dummy.classList.add('hit');
        setTimeout(() => {
            dummy.classList.remove('hit');
            hitTxt.remove();
        }, 300);

        // Check if game complete
        if (hitCount >= totalRequiredHits) {
            setTimeout(() => {
                goToStep(3);
            }, 500);
        }
    }

    function celebrate() {
        alert("Yay! 🎉 You made me the happiest person ever! I promise to always love you and keep you smiling. ❤️");
    }
</script>

</body>
</html>
